{
  "installCommand": "corepack enable pnpm && pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/donghua-stream run build",
  "outputDirectory": "artifacts/donghua-stream/dist",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/donghua/:path*",
      "destination": "https://axlyapi.qzz.io/donghua/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
