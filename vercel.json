{
  "version": 2,
  "installCommand": "npm install -g pnpm@latest && pnpm install",
  "buildCommand": "pnpm --filter @workspace/api-spec run codegen && pnpm --filter @workspace/donghua-stream run build",
  "outputDirectory": "artifacts/donghua-stream/dist",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
